# health-self-healing-hermes — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to git.

# Required: Google AI Studio key (get free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Required for HuggingFace backup/sync
HF_TOKEN=your_huggingface_token_here

# Optional: Live agent API endpoint (leave as-is for simulation mode)
AGENT_API_URL=http://localhost:8000
