                f"            WHERE email='{ADMIN_EMAIL}'\n"
                "            AND (role IS NULL OR role != 'admin')\n"
                "        \"\"\")\n"
                "        conn.commit()\n"
            )
            # Find end of executescript block
            anchor = '        """)\n'
            idx = src.find(anchor)
            if idx == -1:
                return False
            patched = src[:idx + len(anchor)] + ALTER_BLOCK + src[idx + len(anchor):]
            return safe_write(p, patched)

        self.register(dict(id="auth_role_column", priority=10,
            description="Add role column + admin auto-promote to auth.py",
            check=check, apply=apply, files=["auth/auth.py"]))

    # ── FIX 4: TOTP valid_window ──────────────────────────────────────────────
    def _reg_totp_window(self):
