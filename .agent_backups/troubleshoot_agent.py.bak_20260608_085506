    # ── FIX 6: duplicate st.button / st.toggle keys (ALL pages) ──────────────
    def _reg_duplicate_widget_keys(self):
        """
        Scans EVERY .py file for duplicate widget keys and adds unique prefixes.
        Covers ctca_panel_viewer.py and any other pages with the same pattern.
        """
        def check():
            # Look for unqualified key patterns that are likely duplicated
            patterns = [
                r'key=f"sugg_\{i\}"',
                r'key="animate_toggle"',
                r'key="labels_toggle"',
            ]
            for p in patterns:
                if self._find_files_containing(p.replace(r'\{i\}', '{i}').replace('r"','').replace('"','')):
                    return True
            # Also check for st.button/toggle calls WITHOUT keys in pages/
            pages_dir = PROJECT_ROOT / "pages"
            if pages_dir.exists():
                for f in pages_dir.glob("*.py"):
                    try:
                        src = f.read_text(encoding="utf-8", errors="ignore")
                        # Count st.button calls without key= argument
                        btns_without_key = re.findall(
                            r'st\.button\([^)]+\)(?![^)]*key=)', src
                        )
                        if len(btns_without_key) > 1:
                            return True
                    except Exception:
                        pass
            return False

        def apply():
            changed = False
            pages_dir = PROJECT_ROOT / "pages"
            if not pages_dir.exists():
                return False

            for f in pages_dir.glob("*.py"):
                try:
                    src = f.read_text(encoding="utf-8", errors="ignore")
                    original = src
                    prefix = f.stem  # e.g. "ctca_panel_viewer"

                    # Fix generic suggestion loop keys
                    src = src.replace('key=f"sugg_{i}"', f'key=f"{prefix}_sugg_{{i}}"')

                    # Fix toggle keys missing unique prefix
                    for old_pat, new_key in [
                        ('st.toggle("Animate finding dots", value=False)',
                         f'st.toggle("Animate finding dots", value=False, key="{prefix}_animate")'),
                        ('st.toggle("Show slice labels", value=True)',
                         f'st.toggle("Show slice labels", value=True, key="{prefix}_labels")'),
                        ('st.toggle("Show annotations", value=True)',
                         f'st.toggle("Show annotations", value=True, key="{prefix}_annotations")'),
                    ]:
                        if old_pat in src and f'key="{prefix}_' not in src:
                            src = src.replace(old_pat, new_key)

                    # Fix st.button calls in loops without keys
                    def add_key_to_button(m):
                        btn_call = m.group(0)
                        if "key=" in btn_call:
                            return btn_call
                        label_match = re.search(r'st\.button\(["\']([^"\']+)', btn_call)
                        if label_match:
                            label_slug = re.sub(r'\W+', '_', label_match.group(1).lower())[:20]
                            return btn_call.rstrip(')') + f', key="{prefix}_{label_slug}_btn")'
                        return btn_call

                    src = re.sub(r'st\.button\([^)]+\)', add_key_to_button, src)

                    if src != original:
                        safe_write(f, src)
                        log.info(f"  [widget_keys] fixed keys in {f.name}")
                        changed = True
                except Exception as e:
                    log.warning(f"  [widget_keys] could not process {f.name}: {e}")

            return changed

        self.register(dict(id="duplicate_widget_keys", priority=30,
            description="Fix duplicate st.button/toggle keys across all pages",
            check=check, apply=apply, files=["pages/"]))

    # ── FIX 7: page registry (CTCA Panel View) ────────────────────────────────
    def _reg_page_registry(self):
        APP = "app.py"

        def check():
            s = self._src(APP)
            return bool(s) and "ctca_panel_viewer" not in s

        def apply():
            p   = self._file(APP)
            src = p.read_text(encoding="utf-8")

            # Pattern A: dict registry
            new_src, n = re.subn(
                r'("compliance"[^\n]+\n)',
                lambda m: m.group(0) + '    "ctca_panel_view": "pages/ctca_panel_viewer.py",\n',
                src, count=1,
            )
            if n:
                return safe_write(p, new_src)

            # Pattern B: st.Page list
            new_src, n = re.subn(
                r'(st\.Page\(["\']pages/compliance[^)]+\)\s*[,\n])',
                lambda m: m.group(0) + '    st.Page("pages/ctca_panel_viewer.py", title="CTCA Panel View", icon="🫀"),\n',
                src, count=1,
            )
            if n:
                return safe_write(p, new_src)

            log.warning("  [page_registry] could not auto-insert – dumping page-related lines:")
            for i, line in enumerate(src.splitlines()):
                if any(x in line.lower() for x in ["pages/", "compliance", "st.page", "page_map"]):
                    log.info(f"    L{i+1}: {line}")
            return False

        self.register(dict(id="page_registry_ctca", priority=40,
            description="Register CTCA Panel View in app.py page map",
            check=check, apply=apply, files=["app.py"]))

    # ── FIX 8: Clinical Disclaimer — centred modal ────────────────────────────
    def _reg_disclaimer_center(self):
        """
        v2 FIX: Scans ALL .py files (not just a hardcoded list) to find
        where the disclaimer lives, then replaces inline warning with
        a centred st.dialog modal.
        """
        DISCLAIMER_PATTERNS = [
            "WARNING CLINICAL DISCLAIMER",
            "clinical disclaimer",
            "I acknowledge and accept the clinical disclaimer",
        ]
        ALREADY_FIXED_MARKER = "disclaimer_modal_v2"

        def _find_disclaimer_files() -> list[Path]:
            found = []
            for pat in DISCLAIMER_PATTERNS:
                found.extend(self._find_files_containing(pat))
            # Deduplicate
            seen = set()
            result = []
            for f in found:
                if f not in seen:
                    seen.add(f)
                    result.append(f)
            return result

        def check():
            files = _find_disclaimer_files()
            for f in files:
                src = f.read_text(encoding="utf-8", errors="ignore")
                if ALREADY_FIXED_MARKER not in src:
                    return True
            return False

        def apply():
            files = _find_disclaimer_files()
            if not files:
                log.warning("  [disclaimer] Could not find disclaimer in any .py file.")
                log.warning("  [disclaimer] Searched for: " + str(DISCLAIMER_PATTERNS))
                return False

            MODAL_CODE = '''
# ── Clinical Disclaimer Modal (disclaimer_modal_v2 — TroubleshootAgent) ──────
if "disclaimer_accepted" not in st.session_state:
    st.session_state["disclaimer_accepted"] = False

if not st.session_state["disclaimer_accepted"]:
    # Use CSS to create a centred overlay without st.dialog (Streamlit ≥1.35)
    st.markdown("""
    <style>
    .disclaimer-overlay {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: rgba(0,0,0,0.75); z-index: 9999;
        display: flex; align-items: center; justify-content: center;
    }
    .disclaimer-box {
        background: #1a1a2e; border: 2px solid #f59e0b;
        border-radius: 16px; padding: 2.5rem 3rem; max-width: 600px;
        text-align: center; color: #fff;
    }
    .disclaimer-box h2 { color: #f59e0b; margin-bottom: 1rem; font-size: 1.4rem; }
    .disclaimer-box p  { font-size: 1rem; line-height: 1.7; color: #d1d5db; }
    </style>
    <div class="disclaimer-overlay">
      <div class="disclaimer-box">
        <h2>⚕ WARNING — CLINICAL DISCLAIMER</h2>
        <p>AI outputs are for <strong>decision support only</strong> and are
        <strong>not diagnostic</strong>. All findings must be verified with
        clinical data by a qualified healthcare professional before any
        clinical action is taken.</p>
      </div>
    </div>
    """, unsafe_allow_html=True)
    st.markdown("<br>" * 12, unsafe_allow_html=True)
    col_l, col_c, col_r = st.columns([1, 3, 1])
    with col_c:
        if st.button(
            "✓  I acknowledge and accept the clinical disclaimer",
            use_container_width=True,
            type="primary",
            key="clinical_disclaimer_modal_v2_btn",
        ):
            st.session_state["disclaimer_accepted"] = True
            st.rerun()
    st.stop()
# ── End Clinical Disclaimer Modal ─────────────────────────────────────────────
'''
            changed = False
            for f in files:
                src = f.read_text(encoding="utf-8", errors="ignore")
                if ALREADY_FIXED_MARKER in src:
                    log.info(f"  [disclaimer] already fixed in {f.name} – skip")
                    continue

                log.info(f"  [disclaimer] found in {f.name} — applying modal fix")

                # Remove old inline banner + acknowledge button block
                patched = re.sub(
                    r'st\.warning\(["\']WARNING CLINICAL DISCLAIMER[^)]+\)[^\n]*\n?',
                    "",
                    src,
                )
                # Remove old inline acknowledge button (various patterns)
                patched = re.sub(
                    r'if\s+st\.button\(["\']I acknowledge[^)]+\)[\s\S]{0,300}?st\.rerun\(\)',
                    "",
                    patched,
                    flags=re.DOTALL,
                )
                # Remove old disclaimer_accepted session_state block if present
                patched = re.sub(
                    r'if ["\']disclaimer_accepted["\'] not in st\.session_state[\s\S]{0,200}?st\.stop\(\)\s*\n?',
                    "",
                    patched,
                    flags=re.DOTALL,
                )

                # Inject modal at top, after imports
                lines = patched.splitlines()
                last_import_idx = 0
                for i, line in enumerate(lines):
                    if line.startswith(("import ", "from ")):
                        last_import_idx = i
                lines.insert(last_import_idx + 1, MODAL_CODE)
                final = "\n".join(lines)

                if safe_write(f, final):
                    log.info(f"  [disclaimer] ✓ modal applied to {f.name}")
                    changed = True

            return changed

        self.register(dict(id="disclaimer_modal_center", priority=50,
            description="Replace inline disclaimer with centred overlay modal (scans all .py files)",
            check=check, apply=apply, files=["<auto-detected>"]))

    # ── FIX 9: NEXUS single-user mode ─────────────────────────────────────────
    def _reg_nexus_single_user(self):
        def check():
            files = self._find_files_containing("session_key")
            for f in files:
                src = f.read_text(encoding="utf-8", errors="ignore")
                if "NEXUS" in src and "NEXUS_SINGLE_USER_MODE" not in src:
                    return True
            return False

        def apply():
            files = self._find_files_containing("session_key")
            for f in files:
                src = f.read_text(encoding="utf-8", errors="ignore")
                if "NEXUS" not in src or "NEXUS_SINGLE_USER_MODE" in src:
                    continue
                patch = (
                    "\n# NEXUS single-user fallback (TroubleshootAgent)\n"
                    "_NEXUS_SINGLE = os.getenv('NEXUS_SINGLE_USER_MODE', '0') == '1'\n\n"
                )
                patched = patch + src
                if safe_write(f, patched):
                    return True
            return False

        self.register(dict(id="nexus_single_user", priority=60,
            description="Add NEXUS_SINGLE_USER_MODE env fallback",
            check=check, apply=apply, files=["<auto-detected>"]))

    def _register_all(self):
        self._reg_requirements()
        self._reg_remove_reset_endpoint()
        self._reg_auth_role()
        self._reg_totp_window()
        self._reg_db_persistence()
        self._reg_duplicate_widget_keys()
        self._reg_page_registry()
        self._reg_disclaimer_center()
        self._reg_nexus_single_user()


# ─── Orchestrator ─────────────────────────────────────────────────────────────
class TroubleshootAgent:
    def __init__(self, dry_run=False, verbose=False):
        self.dry_run = dry_run
        self.verbose = verbose
        self.registry = FixerRegistry()
        self.applied: list[str] = []
        self.skipped: list[str] = []
        self.failed:  list[str] = []
        if verbose:
            log.setLevel(logging.DEBUG)

    def run(self):
        log.info("=" * 64)
        log.info("HEALTH HERMES // TROUBLESHOOT AGENT v2.0")
        log.info(f"  Project root : {PROJECT_ROOT}")
        log.info(f"  Dry run      : {self.dry_run}")
        log.info(f"  Audit log    : {AUDIT_FILE}")
        log.info(f"  Backups      : {BACKUP_DIR}/")
        log.info("=" * 64)
        audit_log.info(f"=== RUN START dry_run={self.dry_run} ===")

        fixers = self.registry.sorted_fixers()
        log.info(f"Loaded {len(fixers)} fixers\n")

        changed_files: list[str] = []

        for i, fixer in enumerate(fixers, 1):
            fid, desc = fixer["id"], fixer["description"]
            log.info(f"[{i}/{len(fixers)}] {fid}")
            log.info(f"         {desc}")

            try:
                needed = fixer["check"]()
            except Exception as e:
                log.warning(f"  check() raised: {e} — skip")
                self.skipped.append(fid)
                continue

            if not needed:
                log.info("  ✓ OK — skip\n")
                self.skipped.append(fid)
                continue

            log.info("  ⚙ fix needed…")
            if self.dry_run:
                log.info("  [dry-run] skip apply\n")
                self.skipped.append(fid)
                continue

            try:
                ok = fixer["apply"]()
            except Exception as e:
                log.error(f"  apply() raised: {e}")
                ok = False

            if ok:
                log.info(f"  ✓ applied\n")
                self.applied.append(fid)
                changed_files.extend(fixer.get("files", []))
            else:
                log.warning(f"  ✗ failed — trying LLM fallback…")
                self._llm_fallback(fid, desc)
                self.failed.append(fid)

        if changed_files and not self.dry_run:
            existing = [
                str(PROJECT_ROOT / f) for f in dict.fromkeys(changed_files)
                if (PROJECT_ROOT / f).exists()
            ]
            msg = f"auto-fix: {', '.join(self.applied)}"
            log.info(f"\nStaging {len(existing)} files…")
            GitOps.stage(*existing)
            GitOps.commit(msg)
            log.info("Pushing…")
            GitOps.push()
            log.info("\nWaiting 90s for HF Space rebuild…")
            for remaining in range(90, 0, -15):
                log.info(f"  {remaining}s…")
                time.sleep(15)
        elif not changed_files:
            log.info("\nNo changes needed — project is clean ✓")

        self._print_summary()

    def _llm_fallback(self, fid: str, desc: str):
        snippets = {}
        for rel in ["app.py", "auth/auth.py"]:
            p = PROJECT_ROOT / rel
            if p.exists():
                snippets[rel] = p.read_text(encoding="utf-8")[:600]

        code = llm_synthesise_fixer(
            error_text=f"Fixer '{fid}' ({desc}) failed.",
            file_content=str(snippets),
            context={"fixer_id": fid, "admin": ADMIN_EMAIL},
        )
        if code:
            ok = run_synthesised_fixer(code, fid, self.dry_run)
            if ok:
                self.applied.append(f"{fid}_llm")
                log.info(f"  [LLM] ✓ synthesised fixer succeeded\n")
            else:
                log.warning(f"  [LLM] synthesised fixer also failed\n")
        else:
            log.warning("  [LLM] synthesis unavailable\n")

    def _print_summary(self):
        vcount = len(SECURITY.violations)
        log.info("\n" + "=" * 64)
        log.info("SUMMARY")
        log.info(f"  Applied             : {self.applied or ['(none)']}")
        log.info(f"  Skipped (OK)        : {self.skipped or ['(none)']}")
        log.info(f"  Failed              : {self.failed or ['(none)']}")
        log.info(f"  Security violations : {vcount} (see {AUDIT_FILE.name})")
        if not self.failed:
            log.info("\n  🟢 All checks passed.")
            log.info("  → huggingface.co/spaces/aiq00479/health-self-healing-hermes")
        else:
            log.info(f"\n  🔴 {len(self.failed)} fixer(s) failed — check logs.")
            log.info(f"  → Synthesised fixers: {SYNTH_DIR}/")
        if vcount:
            log.info(f"\n  ⚠ {vcount} security violations were BLOCKED — see {AUDIT_FILE}")
        log.info("=" * 64)
        audit_log.info(f"=== RUN END applied={self.applied} failed={self.failed} violations={vcount} ===")


