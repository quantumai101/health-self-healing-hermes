# ─── Backup helper ────────────────────────────────────────────────────────────
def backup(path: Path) -> Path:
    """Copy file into .agent_backups/ before modification. Returns backup path."""
    BACKUP_DIR.mkdir(exist_ok=True)
    ts   = datetime.now().strftime("%Y%m%d_%H%M%S")
    name = path.name + f".bak_{ts}"
    bak  = BACKUP_DIR / name
    shutil.copy2(path, bak)
    audit_log.info(f"BACKUP {path} → {bak}")
    return bak


def safe_write(path: Path, content: str) -> bool:
    """Write file only if SecurityHarness approves. Always backs up first."""
    allowed, reason = SECURITY.check_file_write(path)
    if not allowed:
        return False
    if path.exists():
        backup(path)
    path.write_text(content, encoding="utf-8")
    audit_log.info(f"WRITE {path}")
    return True


# ─── GitOps ───────────────────────────────────────────────────────────────────
class GitOps:
    @staticmethod
    def run(cmd: list[str], check=True):
        allowed, reason = SECURITY.check_git_cmd(cmd)
        if not allowed:
            log.warning(f"  Git command blocked by SecurityHarness: {reason}")
            return False, "", reason

        audit_log.info(f"GIT {' '.join(cmd)}")
        r = subprocess.run(cmd, capture_output=True, text=True, cwd=PROJECT_ROOT)
        ok = r.returncode == 0
        if not ok and check:
            log.warning(f"  Git cmd failed: {r.stderr.strip()[:120]}")
        return ok, r.stdout, r.stderr

    @staticmethod
    def stage(*paths):
        existing = [str(p) for p in paths if Path(p).exists()]
        if existing:
            GitOps.run(["git", "add"] + existing)

    @staticmethod
    def commit(msg: str) -> bool:
        safe_msg = msg[:200]   # cap commit message length
        ok, _, err = GitOps.run(
            ["git", "commit", "-m", f"[TroubleshootAgent v2] {safe_msg}"], check=False
        )
        return ok or "nothing to commit" in err

    @staticmethod
    def push() -> bool:
        success = True
        for remote_branch in GIT_REMOTES:
            remote, branch = remote_branch.split()
            ok, _, err = GitOps.run(["git", "push", remote, branch], check=False)
            if not ok:
                log.warning(f"  Push to {remote}/{branch} failed: {err.strip()[:80]}")
                success = False
            else:
                log.info(f"  ✓ Pushed → {remote}/{branch}")
        return success

    @staticmethod
    def commit_and_push(msg: str, *paths) -> bool:
        GitOps.stage(*paths)
        GitOps.commit(msg)
        return GitOps.push()


# ─── LLM Fixer (Anthropic API) ────────────────────────────────────────────────
def llm_synthesise_fixer(error_text: str, file_content: str, context: dict) -> Optional[str]:
    if not ANTHROPIC_KEY:
        log.warning("  ANTHROPIC_API_KEY not set – LLM synthesis unavailable.")
        return None
    try:
        import anthropic
    except ImportError:
        log.warning("  anthropic not installed – pip install anthropic")
        return None

    client = anthropic.Anthropic(api_key=ANTHROPIC_KEY)
    system = textwrap.dedent("""
        You are an expert Python + Streamlit engineer for the Health Digital Workforce
        platform (health-self-healing-hermes).

        Produce a MINIMAL, SAFE patch function:

            def apply(root: Path) -> bool:
                \"\"\"One-line description.\"\"\"
                ...
                return True

        STRICT RULES — your code will be security-scanned before execution:
        - NO subprocess, os.system, os.popen, os.remove, os.unlink calls.
        - NO shutil.rmtree, shutil.move calls.
        - NO file writes outside root/.
        - NO git operations — the orchestrator handles git.
        - Always backup before modifying: shutil.copy2(f, Path(str(f)+'.bak_synth'))
        - Return False if preconditions not met.
        - Output ONLY the function. No markdown fences. Under 60 lines.
    """).strip()

    user = f"ERROR:\n{error_text[:800]}\n\nFILE:\n{file_content[:1000]}\n\nCONTEXT:\n{json.dumps(context)[:300]}\n\nProduce apply()."

    try:
        resp = client.messages.create(
            model="claude-sonnet-4-20250514",
            max_tokens=1024,
            system=system,
            messages=[{"role": "user", "content": user}],
        )
        raw = resp.content[0].text.strip()
        raw = re.sub(r"^```python\n?", "", raw)
        raw = re.sub(r"\n?```$", "", raw)
        return raw.strip()
    except Exception as e:
        log.error(f"  LLM API error: {e}")
        return None


def run_synthesised_fixer(code: str, label: str, dry_run: bool) -> bool:
    SYNTH_DIR.mkdir(exist_ok=True)
    slug = hashlib.md5(label.encode()).hexdigest()[:8]
    fixer_path = SYNTH_DIR / f"synth_{slug}.py"

    # ── Security scan BEFORE writing or running ──
    allowed, reason = SECURITY.check_synthesised_code(code)
    if not allowed:
        log.error(f"  [LLM-Synth] code REJECTED by SecurityHarness: {reason}")
        return False

    fixer_path.write_text(code, encoding="utf-8")
    audit_log.info(f"SYNTH_WRITE {fixer_path}")
    log.info(f"  [LLM-Synth] fixer saved → {fixer_path.name}")

    if dry_run:
        log.info("  [LLM-Synth] dry-run: not executing")
        return False

    # Restricted namespace — no dangerous builtins exposed
    safe_ns = {
        "Path": Path,
        "re": re,
        "shutil": shutil,
        "__name__": "__synth__",
        "__builtins__": {
            k: __builtins__[k] if isinstance(__builtins__, dict) else getattr(__builtins__, k)
            for k in [
                "open", "len", "str", "int", "bool", "list", "dict", "tuple",
                "print", "range", "enumerate", "isinstance", "hasattr",
                "getattr", "setattr", "Exception", "True", "False", "None",
            ]
            if (isinstance(__builtins__, dict) and k in __builtins__)
               or (not isinstance(__builtins__, dict) and hasattr(__builtins__, k))
        },
    }
    try:
        exec(compile(code, str(fixer_path), "exec"), safe_ns)
        apply_fn = safe_ns.get("apply")
        if not apply_fn:
            log.error("  [LLM-Synth] no apply() found")
            return False
        result = bool(apply_fn(PROJECT_ROOT))
        audit_log.info(f"SYNTH_EXEC {label} result={result}")
        return result
    except Exception as e:
        log.error(f"  [LLM-Synth] execution error: {e}")
        return False


# ─── Fixer Registry ───────────────────────────────────────────────────────────
class FixerRegistry:
    def __init__(self):
        self._fixers: list[dict] = []
        self._register_all()

    def register(self, fixer: dict):
        self._fixers.append(fixer)

    def sorted_fixers(self) -> list[dict]:
        return sorted(self._fixers, key=lambda f: f.get("priority", 99))

    def _file(self, rel) -> Path:
        return PROJECT_ROOT / rel

    def _src(self, rel) -> str:
        p = self._file(rel)
        return p.read_text(encoding="utf-8") if p.exists() else ""

    def _find_files_containing(self, pattern: str, extensions=(".py",)) -> list[Path]:
        """Recursively scan project for files containing `pattern`."""
        matches = []
        for ext in extensions:
            for f in PROJECT_ROOT.rglob(f"*{ext}"):
                # Skip hidden dirs, backups, synth dir, venv
                skip_parts = {".git", "__pycache__", ".venv", "venv",
                              "agent_fixes_synth", ".agent_backups"}
                if any(p in skip_parts for p in f.parts):
                    continue
                try:
                    if pattern in f.read_text(encoding="utf-8", errors="ignore"):
                        matches.append(f)
                except Exception:
                    pass
        return matches

    # ── FIX 1: requirements baseline ──────────────────────────────────────────
    def _reg_requirements(self):
        REQ = "requirements.txt"
        NEEDED = {
            "pyotp":       "pyotp>=2.9.0",
            "pydicom":     "pydicom>=2.4.0",
            "duckdb":      "duckdb>=0.10.0",
            "streamlit":   "streamlit>=1.35.0",
            "huggingface_hub": "huggingface_hub>=0.20.0",
        }

        def check():
            s = self._src(REQ)
            return any(k not in s for k in NEEDED)

        def apply():
            p   = self._file(REQ)
            txt = p.read_text(encoding="utf-8") if p.exists() else ""
            for k, spec in NEEDED.items():
                if k not in txt:
                    txt = txt.rstrip() + f"\n{spec}\n"
            return safe_write(p, txt)

        self.register(dict(id="requirements_baseline", priority=2,
            description="Ensure baseline Python deps in requirements.txt",
            check=check, apply=apply, files=["requirements.txt"]))

    # ── FIX 2: remove temp reset endpoint ────────────────────────────────────
    def _reg_remove_reset_endpoint(self):
        MARKER = "# TEMP: reset endpoint"

        def check():
            files = self._find_files_containing(MARKER)
            return len(files) > 0

        def apply():
            files = self._find_files_containing(MARKER)
            ok = False
            for p in files:
                src = p.read_text(encoding="utf-8")
                patched = re.sub(
                    rf"{re.escape(MARKER)}.*?(?=\ndef |\nclass |\nif __name__)",
                    "", src, flags=re.DOTALL,
                )
                if patched != src:
                    ok = safe_write(p, patched) or ok
            return ok

        self.register(dict(id="remove_temp_reset", priority=5,
            description="Remove temporary /reset endpoint",
            check=check, apply=apply, files=["app.py"]))

    # ── FIX 3: auth role column ───────────────────────────────────────────────
    def _reg_auth_role(self):
        AUTH = "auth/auth.py"
        MARKER = "AUTO-PROMOTE"

        def check():
            s = self._src(AUTH)
            return bool(s) and MARKER not in s

        def apply():
            p   = self._file(AUTH)
            src = p.read_text(encoding="utf-8")
            # Try ALTER TABLE approach (works on existing DBs)
            ALTER_BLOCK = (
                "\n        # Add role column if upgrading existing DB\n"
                "        try:\n"
                "            conn.execute(\"ALTER TABLE users ADD COLUMN role TEXT DEFAULT 'user'\")\n"
                "            conn.commit()\n"
                "        except Exception:\n"
                "            pass\n"
                "\n        # AUTO-PROMOTE admin\n"
                "        conn.execute(\"\"\"\n"
