# SECURITY HARNESS
# Every destructive operation goes through this class first.
# If it is not on the allow-list it is BLOCKED and logged.
# ═══════════════════════════════════════════════════════════════════════════════
class SecurityHarness:
    """
    Enforces the principle of least privilege for the agent.

    WHAT IT BLOCKS (always):
      - git rm, git clean, git reset --hard, git push --force
      - git push to any remote NOT in ALLOWED_REMOTES
      - Any shell command containing rm -rf, shutil.rmtree, os.remove on
        project root or parent directories
      - Writing outside PROJECT_ROOT
      - Deleting .py, .db, .toml, .yaml, .json files (only BACKUP copies allowed)
      - Pushing branches other than 'main'

    WHAT IT ALLOWS:
      - git add, git commit, git push <allowed_remote> main
      - Writing/overwriting .py files INSIDE PROJECT_ROOT (after backup)
      - Appending to requirements.txt
      - Creating new files inside PROJECT_ROOT
    """

    ALLOWED_REMOTES = {"huggingface", "origin"}
    ALLOWED_BRANCH  = "main"

    # Git sub-commands that are NEVER allowed regardless of args
    BLOCKED_GIT_SUBCMDS = {
        "rm", "clean", "bisect", "filter-branch",
        "update-ref", "symbolic-ref",
    }

    # Git flags that are never allowed
    BLOCKED_GIT_FLAGS = {"--force", "-f", "--hard", "--mirror", "--delete"}

    # Shell tokens that suggest destructive intent
    BLOCKED_SHELL_TOKENS = {
        "rm -rf", "rmdir /s", "shutil.rmtree", "os.remove(",
        "os.unlink(", "pathlib.Path.unlink", ".unlink(",
        "DELETE FROM", "DROP TABLE", "TRUNCATE",
    }

    def __init__(self):
        self._violations: list[str] = []

    @property
    def violations(self):
        return list(self._violations)

    def check_git_cmd(self, cmd: list[str]) -> tuple[bool, str]:
        """
        Returns (allowed: bool, reason: str).
        Call BEFORE any subprocess git invocation.
        """
        if not cmd or cmd[0] != "git":
            return True, "ok"

        subcmd = cmd[1] if len(cmd) > 1 else ""

        # Block forbidden sub-commands
        if subcmd in self.BLOCKED_GIT_SUBCMDS:
            reason = f"BLOCKED git sub-command: {subcmd}"
            self._record_violation(reason, cmd)
            return False, reason

        # Block forbidden flags in any position
        for flag in self.BLOCKED_GIT_FLAGS:
            if flag in cmd:
                reason = f"BLOCKED git flag: {flag}"
                self._record_violation(reason, cmd)
                return False, reason

        # For push: only to allowed remotes, only 'main' branch
        if subcmd == "push":
            # cmd structure: git push <remote> <branch>
            remote = cmd[2] if len(cmd) > 2 else ""
            branch = cmd[3] if len(cmd) > 3 else ""
            if remote not in self.ALLOWED_REMOTES:
                reason = f"BLOCKED push to non-whitelisted remote: '{remote}'"
                self._record_violation(reason, cmd)
                return False, reason
            if branch and branch != self.ALLOWED_BRANCH:
                reason = f"BLOCKED push to non-main branch: '{branch}'"
                self._record_violation(reason, cmd)
                return False, reason

        return True, "ok"

    def check_file_write(self, path: Path) -> tuple[bool, str]:
        """
        Returns (allowed: bool, reason: str).
        Call BEFORE writing or creating any file.
        """
        path = path.resolve()
        root = PROJECT_ROOT.resolve()

        # Must stay inside project root
        try:
            path.relative_to(root)
        except ValueError:
            reason = f"BLOCKED write outside project root: {path}"
            self._record_violation(reason, str(path))
            return False, reason

        # Never write into .git/
        if ".git" in path.parts:
            reason = f"BLOCKED write into .git directory: {path}"
            self._record_violation(reason, str(path))
            return False, reason

        return True, "ok"

    def check_file_delete(self, path: Path) -> tuple[bool, str]:
        """Deleting source files is NEVER allowed."""
        reason = f"BLOCKED file deletion attempt: {path}"
        self._record_violation(reason, str(path))
        return False, reason

    def check_synthesised_code(self, code: str) -> tuple[bool, str]:
        """
        Scan LLM-generated code for dangerous tokens before exec().
        """
        for token in self.BLOCKED_SHELL_TOKENS:
            if token in code:
                reason = f"BLOCKED synthesised code contains dangerous token: '{token}'"
                self._record_violation(reason, f"code snippet: {code[:120]}")
                return False, reason
        # Block subprocess / os.system calls in synth code
        if re.search(r'\bsubprocess\b|\bos\.system\b|\bos\.popen\b', code):
            reason = "BLOCKED synthesised code attempts subprocess/os.system call"
            self._record_violation(reason, f"code snippet: {code[:120]}")
            return False, reason
        return True, "ok"

    def _record_violation(self, reason: str, detail):
        entry = f"SECURITY VIOLATION: {reason} | detail={detail}"
        self._violations.append(entry)
        audit_log.warning(entry)
        log.error(f"  🔴 {entry}")


# Singleton — shared by all components
